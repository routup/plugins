{
    "name": "@routup/swagger",
    "version": "2.4.3",
    "type": "module",
    "description": "Swagger plugin for routup.",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "types": "./dist/index.d.mts",
    "files": [
        "assets/",
        "dist/"
    ],
    "scripts": {
        "build": "npm run build:js && npm run build:types",
        "build:js": "rimraf ./dist && tsdown",
        "build:types": "tsc --noEmit -p tsconfig.build.json",
        "test": "vitest run --config ./test/vitest.config.ts",
        "test:coverage": "vitest run --config ./test/vitest.config.ts --coverage",
        "lint": "eslint ./src",
        "lint:fix": "npm run lint -- --fix"
    },
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "license": "MIT",
    "keywords": [
        "swagger",
        "swagger-ui",
        "openapi",
        "api",
        "rest",
        "http",
        "router",
        "api-router",
        "route",
        "routing"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/routup/plugins.git",
        "directory": "packages/swagger"
    },
    "bugs": {
        "url": "https://github.com/routup/plugins/issues"
    },
    "homepage": "https://github.com/routup/plugins#readme",
    "peerDependencies": {
        "routup": "^5.0.0-beta.4"
    },
    "dependencies": {
        "@routup/assets": "^3.4.2",
        "@routup/swagger-preset": "^2.4.3",
        "@trapi/metadata": "^2.0.0-beta.0",
        "@trapi/swagger": "^2.0.0-beta.0",
        "@types/swagger-ui-dist": "^3.30.5",
        "smob": "^1.4.0",
        "swagger-ui-dist": "^5.32.2"
    },
    "devDependencies": {
        "@routup/decorators": "^3.4.3",
        "jsonata": "^2.1.0",
        "routup": "^5.0.0-beta.4"
    },
    "publishConfig": {
        "access": "public"
    },
    "gitHead": "94d729e309c1eec0401afb4d8083f65ce3aa8e0b"
}
