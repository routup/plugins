{
    "name": "@routup/i18n",
    "version": "2.0.2",
    "type": "module",
    "description": "Translation and internationalization plugin for routup.",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "types": "./dist/index.d.mts",
    "files": [
        "dist/"
    ],
    "scripts": {
        "build": "npm run build:js && npm run build:types",
        "build:js": "rimraf ./dist && tsdown",
        "build:types": "tsc --noEmit -p tsconfig.build.json",
        "test": "vitest run --config ./test/vitest.config.ts",
        "test:coverage": "vitest run --config ./test/vitest.config.ts --coverage",
        "lint": "eslint ./src",
        "lint:fix": "npm run lint -- --fix"
    },
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "license": "MIT",
    "keywords": [
        "i18n",
        "translation",
        "internationalization",
        "language",
        "bilingual",
        "translate"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/routup/plugins.git",
        "directory": "packages/i18n"
    },
    "bugs": {
        "url": "https://github.com/routup/plugins/issues"
    },
    "homepage": "https://github.com/routup/plugins#readme",
    "peerDependencies": {
        "ilingo": "^3.2.0",
        "routup": "^5.0.0-beta.3"
    },
    "devDependencies": {
        "@types/supertest": "^7.2.0",
        "ilingo": "^5.0.0",
        "routup": "^5.0.0-beta.3",
        "supertest": "^7.1.4"
    },
    "gitHead": "94d729e309c1eec0401afb4d8083f65ce3aa8e0b",
    "publishConfig": {
        "access": "public"
    }
}
